<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="email_template_agreement_signing" model="mail.template">
            <field name="name">Contract Ready for Signing</field>
            <field name="model_id" ref="amb_crm.model_amb_agreement"/>
            <field name="email_from">{{ object.company_id.email or 'noreply@example.com' }}</field>
            <field name="email_to">{{ object.partner_id.email }}</field>
            <field name="subject">Your Service Agreement is Ready for Signing - {{ object.name }}</field>
            <field name="body_html" type="html">
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
    <h2 style="color: #333;">Dear {{ object.partner_id.name }},</h2>
    <p>Your service agreement <strong>{{ object.name }}</strong> has been prepared and is ready for your review and signature.</p>
    <p>Please click the button below to view and sign your agreement in the client portal:</p>
    <p style="text-align: center; margin: 30px 0;">
        <a href="{{ object.get_base_url() }}/my/agreements/{{ object.id }}?access_token={{ object.access_token }}"
           style="background-color: #875A7B; color: white; padding: 12px 24px; text-decoration: none; border-radius: 4px; font-size: 16px;">
            View &amp; Sign Agreement
        </a>
    </p>
    <p>Or copy and paste this link into your browser:</p>
    <p style="word-break: break-all; color: #666;">
        {{ object.get_base_url() }}/my/agreements/{{ object.id }}?access_token={{ object.access_token }}
    </p>
    <hr style="border: none; border-top: 1px solid #eee; margin: 20px 0;"/>
    <p style="color: #999; font-size: 12px;">
        If you did not expect this email, please contact us at {{ object.company_id.email or '' }}.
    </p>
</div>
            </field>
            <field name="lang">{{ object.partner_id.lang }}</field>
        </record>

        <record id="email_template_contract_signed" model="mail.template">
            <field name="name">Contract Signed Notification</field>
            <field name="model_id" ref="amb_crm.model_amb_agreement"/>
            <field name="email_from">{{ object.company_id.email or 'noreply@example.com' }}</field>
            <field name="email_to">{{ object.user_id.email or object.company_id.email }}</field>
            <field name="subject">Contract Signed - {{ object.name }}</field>
            <field name="body_html" type="html">
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
    <h2 style="color: #28a745;">Contract Signed Successfully</h2>
    <p>The following agreement has been signed:</p>
    <ul>
        <li><strong>Agreement:</strong> {{ object.name }}</li>
        <li><strong>Signed by:</strong> {{ object.signer_name }}</li>
        <li><strong>Date:</strong> {{ object.signature_date }}</li>
        <li><strong>Customer:</strong> {{ object.partner_id.name }}</li>
    </ul>
</div>
            </field>
            <field name="lang">{{ object.user_id.lang or object.company_id.partner_id.lang }}</field>
        </record>
    </data>
</odoo>
