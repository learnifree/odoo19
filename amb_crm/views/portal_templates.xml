<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Contract Signing Page Template -->
    <template id="amb_crm.contract_sign_page" name="Sign Contract">
        <t t-call="website.layout">
            <div class="container">
                <div class="row mt-4">
                    <div class="col-md-10 offset-md-1">
                        <div class="card">
                            <div class="card-header">
                                <h3 class="mb-0">Service Agreement - Sign Contract</h3>
                            </div>
                            <div class="card-body">
                                <!-- Contract Info -->
                                <div class="alert alert-info">
                                    <strong>Agreement:</strong> <t t-esc="agreement.name"/>
                                    <br/>
                                    <strong>Service:</strong> <t t-esc="agreement.agreement_type"/> 
                                    <span t-if="agreement.program_type"> - <t t-esc="agreement.program_type.name"/></span>
                                </div>
                                
                                <!-- Error Message -->
                                <div t-if="error" class="alert alert-danger">
                                    <t t-esc="error"/>
                                </div>
                                
                                <!-- Contract Content -->
                                <div class="contract-content border p-3 mb-4" style="max-height: 400px; overflow-y: auto;">
                                    <t t-raw="agreement.body_html"/>
                                </div>
                                
                                <!-- Signature Form -->
                                <form action="#" method="POST" id="signature-form">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    
                                    <div class="form-group">
                                        <label for="signer_name"><strong>Full Name (Type to sign)</strong></label>
                                        <input type="text" name="signer_name" id="signer_name" class="form-control" 
                                               placeholder="Enter your full name" required="1"
                                               t-att-value="agreement.partner_id.name"/>
                                    </div>
                                    
                                    <div class="form-group">
                                        <label><strong>Draw Your Signature</strong></label>
                                        <div class="signature-canvas border" style="width: 100%; height: 150px; background: #f9f9f9;">
                                            <canvas id="signature-canvas" width="600" height="150" style="cursor: crosshair;"></canvas>
                                        </div>
                                        <input type="hidden" name="signature_data" id="signature_data"/>
                                        <button type="button" class="btn btn-secondary mt-2" id="clear-signature">Clear Signature</button>
                                    </div>
                                    
                                    <div class="form-group">
                                        <div class="checkbox">
                                            <label>
                                                <input type="checkbox" id="agree_terms" required="1"/>
                                                I have read and agree to the terms and conditions of this agreement.
                                            </label>
                                        </div>
                                    </div>
                                    
                                    <button type="submit" class="btn btn-primary btn-lg" id="submit-signature">
                                        <i class="fa fa-pencil"></i> Submit Signature
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <script>
                $(document).ready(function() {
                    var canvas = document.getElementById('signature-canvas');
                    var ctx = canvas.getContext('2d');
                    var drawing = false;
                    
                    // Set canvas size
                    canvas.width = canvas.parentElement.offsetWidth;
                    canvas.height = 150;
                    
                    // Mouse events
                    canvas.addEventListener('mousedown', function(e) {
                        drawing = true;
                        ctx.beginPath();
                        ctx.moveTo(e.offsetX, e.offsetY);
                    });
                    
                    canvas.addEventListener('mousemove', function(e) {
                        if (drawing) {
                            ctx.lineTo(e.offsetX, e.offsetY);
                            ctx.stroke();
                        }
                    });
                    
                    canvas.addEventListener('mouseup', function() {
                        drawing = false;
                        // Save signature data
                        document.getElementById('signature_data').value = canvas.toDataURL();
                    });
                    
                    canvas.addEventListener('mouseout', function() {
                        if (drawing) {
                            drawing = false;
                            document.getElementById('signature_data').value = canvas.toDataURL();
                        }
                    });
                    
                    // Clear button
                    document.getElementById('clear-signature').addEventListener('click', function() {
                        ctx.clearRect(0, 0, canvas.width, canvas.height);
                        document.getElementById('signature_data').value = '';
                    });
                    
                    // Form submit
                    document.getElementById('signature-form').addEventListener('submit', function(e) {
                        e.preventDefault();
                        
                        // Validate signature
                        var signatureData = document.getElementById('signature_data').value;
                        if (!signatureData) {
                            alert('Please draw your signature before submitting.');
                            return;
                        }
                        
                        // Validate name
                        var signerName = document.getElementById('signer_name').value;
                        if (!signerName) {
                            alert('Please enter your name.');
                            return;
                        }
                        
                        // Validate terms
                        if (!document.getElementById('agree_terms').checked) {
                            alert('Please agree to the terms and conditions.');
                            return;
                        }
                        
                        // Submit via form
                        var formData = new FormData();
                        formData.append('signer_name', signerName);
                        formData.append('signature_data', signatureData);
                        
                        fetch('/amb/contract/' + <t t-esc="agreement.id"/> + '/sign', {
                            method: 'POST',
                            body: formData,
                            headers: {
                                'X-CSRF-Token': document.querySelector('input[name="csrf_token"]').value
                            }
                        }).then(response => response.text())
                          .then(html => {
                              document.body.innerHTML = html;
                          })
                          .catch(error => {
                              alert('Error submitting signature: ' + error);
                          });
                    });
                });
            </script>
        </t>
    </template>
    
    <!-- Already Signed Page -->
    <template id="amb_crm.contract_already_signed" name="Contract Already Signed">
        <t t-call="website.layout">
            <div class="container">
                <div class="row mt-4">
                    <div class="col-md-8 offset-md-2">
                        <div class="alert alert-success text-center">
                            <h2><i class="fa fa-check-circle"></i> Contract Already Signed</h2>
                            <p>This contract has already been signed on <t t-esc="agreement.signature_date"/></p>
                            <p><strong>Signer:</strong> <t t-esc="agreement.signer_name"/></p>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
    
    <!-- Contract Not Available Page -->
    <template id="amb_crm.contract_not_available" name="Contract Not Available">
        <t t-call="website.layout">
            <div class="container">
                <div class="row mt-4">
                    <div class="col-md-8 offset-md-2">
                        <div class="alert alert-warning text-center">
                            <h2><i class="fa fa-exclamation-triangle"></i> Contract Not Available</h2>
                            <p>This contract is no longer available for signing.</p>
                            <p t-if="error"><t t-esc="error"/></p>
                            <p>Current status: <strong t-esc="agreement.state"/></p>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
    
    <!-- Success Page -->
    <template id="amb_crm.contract_signed_success" name="Contract Signed Successfully">
        <t t-call="website.layout">
            <div class="container">
                <div class="row mt-4">
                    <div class="col-md-10 offset-md-1">
                        <div class="card border-success">
                            <div class="card-header bg-success text-white">
                                <h3 class="mb-0"><i class="fa fa-check-circle"></i> Contract Signed Successfully!</h3>
                            </div>
                            <div class="card-body text-center">
                                <p class="lead">Thank you for signing the agreement.</p>
                                
                                <div class="my-4">
                                    <h4><t t-esc="agreement.name"/></h4>
                                    <p><strong>Signed by:</strong> <t t-esc="agreement.signer_name"/></p>
                                    <p><strong>Date:</strong> <t t-esc="agreement.signature_date"/></p>
                                </div>
                                
                                <p class="text-muted">
                                    A copy of this signed agreement will be sent to your email.
                                    Our team will contact you shortly.
                                </p>
                                
                                <a href="/my" class="btn btn-primary">
                                    <i class="fa fa-home"></i> Go to My Account
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>