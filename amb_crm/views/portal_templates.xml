<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Portal Home: Add "Agreements" counter to /my dashboard
         Inherits the standard portal home template to inject our
         counter widget alongside invoices, orders, etc.
    ============================================================ -->
    <template id="portal_my_home_agreement" name="Portal My Home: Agreements"
              inherit_id="portal.portal_my_home"
              customize_show="True"
              priority="30">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Agreements</t>
                <t t-set="url">/my/agreements</t>
                <t t-set="placeholder_count">agreement_count</t>
            </t>
        </xpath>
    </template>

    <!-- ============================================================
         /my/agreements  — Agreement List Page
    ============================================================ -->
    <template id="portal_my_agreements" name="My Agreements">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_searchbar">
                <t t-set="title">Agreements</t>
            </t>

            <t t-if="not agreements">
                <div class="alert alert-warning mt-3">
                    <p class="mb-0">You have no agreements yet.</p>
                </div>
            </t>

            <t t-if="agreements">
                <div class="card mt-3">
                    <div class="table-responsive">
                        <table class="table table-hover o_portal_my_doc_table mb-0">
                            <thead>
                                <tr class="active">
                                    <th>Reference</th>
                                    <th>Type</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="agreements" t-as="agreement">
                                    <tr>
                                        <td>
                                            <a t-att-href="agreement.get_portal_url()">
                                                <t t-esc="agreement.name"/>
                                            </a>
                                        </td>
                                        <td><t t-esc="agreement.agreement_type"/></td>
                                        <td>
                                            <span t-field="agreement.create_date"
                                                  t-options='{"widget": "date"}'/>
                                        </td>
                                        <td>
                                            <span t-if="agreement.state == 'sent'"
                                                  class="badge badge-warning">Pending Signature</span>
                                            <span t-elif="agreement.state == 'signed'"
                                                  class="badge badge-success">Signed</span>
                                            <span t-elif="agreement.state == 'active'"
                                                  class="badge badge-primary">Active</span>
                                            <span t-elif="agreement.state == 'partially_signed'"
                                                  class="badge badge-info">Partially Signed</span>
                                            <span t-else=""
                                                  class="badge badge-secondary">
                                                <t t-esc="agreement.state"/>
                                            </span>
                                        </td>
                                        <td class="text-right">
                                            <a t-att-href="agreement.get_portal_url()"
                                               class="btn btn-sm btn-primary">
                                                <t t-if="agreement.state in ('sent', 'partially_signed')">
                                                    Sign
                                                </t>
                                                <t t-else="">View</t>
                                            </a>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div t-if="pager" class="o_portal_pager text-center mt-3">
                    <t t-call="portal.pager"/>
                </div>
            </t>
        </t>
    </template>

    <!-- ============================================================
         /my/agreements/<id>  — Agreement Detail / Signing Page
         FIX: form action uses t-att-action="form_action" (passed by
         controller) so the token stays in the URL.
         FIX: JS fetch posts to form_action URL, not the old
         /amb/contract/<id>/sign route that no longer exists.
    ============================================================ -->
    <template id="contract_sign_page" name="Sign Agreement">
        <t t-call="portal.portal_layout">
            <t t-set="o_portal_fullwidth_alert" groups="base.group_user">
                <t t-call="portal.portal_back_in_edit_mode">
                    <t t-set="backend_url"
                       t-value="'/web#model=amb.agreement&amp;id=%s&amp;view_type=form' % agreement.id"/>
                </t>
            </t>

            <div class="row mt-4">
                <div class="col-md-10 offset-md-1">
                    <div class="card">
                        <div class="card-header bg-primary text-white">
                            <h3 class="mb-0">
                                <i class="fa fa-file-text-o"/> Service Agreement — Sign Contract
                            </h3>
                        </div>
                        <div class="card-body">

                            <!-- Agreement Info -->
                            <div class="alert alert-info">
                                <strong>Agreement:</strong> <t t-esc="agreement.name"/>
                                <br/>
                                <strong>Type:</strong> <t t-esc="agreement.agreement_type"/>
                                <span t-if="agreement.program_type">
                                    — <t t-esc="agreement.program_type.name"/>
                                </span>
                                <br t-if="agreement.start_date"/>
                                <span t-if="agreement.start_date">
                                    <strong>Date:</strong>
                                    <span t-field="agreement.start_date"/>
                                </span>
                            </div>

                            <!-- Error Message -->
                            <div t-if="error" class="alert alert-danger">
                                <i class="fa fa-exclamation-circle"/> <t t-esc="error"/>
                            </div>

                            <!-- Contract Content -->
                            <div class="contract-content border rounded p-3 mb-4 bg-light"
                                 style="max-height: 450px; overflow-y: auto;">
                                <t t-out="agreement.body_html"/>
                            </div>

                            <!-- Terms & Conditions (if any) -->
                            <div t-if="agreement.terms_conditions"
                                 class="border rounded p-3 mb-4 bg-light"
                                 style="max-height: 200px; overflow-y: auto;">
                                <h5>Terms &amp; Conditions</h5>
                                <t t-out="agreement.terms_conditions"/>
                            </div>

                            <!-- Signature Form
                                 FIX: action uses form_action from controller
                                 (includes ?access_token=... when needed).
                                 The JS fetch also posts to form_action so the
                                 token is never lost.
                            -->
                            <form t-att-action="form_action" method="POST" id="signature-form">
                                <input type="hidden" name="csrf_token"
                                       t-att-value="request.csrf_token()"/>

                                <div class="form-group mb-3">
                                    <label for="signer_name">
                                        <strong>Full Name (as it will appear on the agreement)</strong>
                                    </label>
                                    <input type="text"
                                           name="signer_name"
                                           id="signer_name"
                                           class="form-control"
                                           placeholder="Enter your full legal name"
                                           required="required"
                                           t-att-value="agreement.partner_id.name or ''"/>
                                </div>

                                <div class="form-group mb-3">
                                    <label><strong>Draw Your Signature</strong></label>
                                    <div class="border rounded"
                                         style="width: 100%; height: 160px; background: #fff; position: relative;">
                                        <canvas id="signature-canvas"
                                                style="cursor: crosshair; display: block;"/>
                                    </div>
                                    <input type="hidden" name="signature_data" id="signature_data"/>
                                    <button type="button"
                                            class="btn btn-sm btn-secondary mt-2"
                                            id="clear-signature">
                                        <i class="fa fa-eraser"/> Clear Signature
                                    </button>
                                </div>

                                <div class="form-group mb-4">
                                    <div class="form-check">
                                        <input type="checkbox"
                                               class="form-check-input"
                                               id="agree_terms"
                                               required="required"/>
                                        <label class="form-check-label" for="agree_terms">
                                            I have read and agree to the terms and conditions
                                            of this agreement.
                                        </label>
                                    </div>
                                </div>

                                <button type="submit"
                                        class="btn btn-primary btn-lg"
                                        id="submit-signature">
                                    <i class="fa fa-pencil"/> Submit Signature
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <script type="text/javascript">
                (function () {
                    'use strict';

                    var canvas  = document.getElementById('signature-canvas');
                    var wrapper = canvas.parentElement;
                    var ctx     = canvas.getContext('2d');
                    var drawing = false;

                    // Size canvas to its wrapper
                    function resizeCanvas() {
                        canvas.width  = wrapper.offsetWidth;
                        canvas.height = wrapper.offsetHeight;
                    }
                    resizeCanvas();
                    window.addEventListener('resize', resizeCanvas);

                    function getPos(e) {
                        var rect = canvas.getBoundingClientRect();
                        if (e.touches) {
                            return {
                                x: e.touches[0].clientX - rect.left,
                                y: e.touches[0].clientY - rect.top
                            };
                        }
                        return { x: e.offsetX, y: e.offsetY };
                    }

                    canvas.addEventListener('mousedown',  function (e) {
                        drawing = true;
                        var p = getPos(e);
                        ctx.beginPath();
                        ctx.moveTo(p.x, p.y);
                    });
                    canvas.addEventListener('mousemove',  function (e) {
                        if (!drawing) return;
                        var p = getPos(e);
                        ctx.lineTo(p.x, p.y);
                        ctx.stroke();
                    });
                    canvas.addEventListener('mouseup',    function () { drawing = false; saveData(); });
                    canvas.addEventListener('mouseleave', function () { if (drawing) { drawing = false; saveData(); } });

                    // Touch support
                    canvas.addEventListener('touchstart', function (e) {
                        e.preventDefault();
                        drawing = true;
                        var p = getPos(e);
                        ctx.beginPath();
                        ctx.moveTo(p.x, p.y);
                    }, { passive: false });
                    canvas.addEventListener('touchmove', function (e) {
                        e.preventDefault();
                        if (!drawing) return;
                        var p = getPos(e);
                        ctx.lineTo(p.x, p.y);
                        ctx.stroke();
                    }, { passive: false });
                    canvas.addEventListener('touchend', function () { drawing = false; saveData(); });

                    function saveData() {
                        document.getElementById('signature_data').value = canvas.toDataURL('image/png');
                    }

                    document.getElementById('clear-signature').addEventListener('click', function () {
                        ctx.clearRect(0, 0, canvas.width, canvas.height);
                        document.getElementById('signature_data').value = '';
                    });

                    // Client-side validation before submit
                    document.getElementById('signature-form').addEventListener('submit', function (e) {
                        var signerName    = document.getElementById('signer_name').value.trim();
                        var signatureData = document.getElementById('signature_data').value;
                        var agreeTerms    = document.getElementById('agree_terms').checked;

                        if (!signerName) {
                            e.preventDefault();
                            alert('Please enter your full name.');
                            return;
                        }
                        if (!signatureData) {
                            e.preventDefault();
                            alert('Please draw your signature before submitting.');
                            return;
                        }
                        if (!agreeTerms) {
                            e.preventDefault();
                            alert('Please agree to the terms and conditions.');
                            return;
                        }
                        // Allow native form submit — action is already set to form_action
                        // which includes the access_token in the URL query string.
                    });
                })();
            </script>
        </t>
    </template>

    <!-- ============================================================
         Already Signed Page
    ============================================================ -->
    <template id="contract_already_signed" name="Contract Already Signed">
        <t t-call="portal.portal_layout">
            <div class="row mt-4">
                <div class="col-md-8 offset-md-2">
                    <div class="alert alert-success text-center">
                        <h2><i class="fa fa-check-circle"/> Agreement Already Signed</h2>
                        <p>This agreement was signed on
                            <strong><span t-field="agreement.signature_date"/></strong>.
                        </p>
                        <p><strong>Signed by:</strong> <t t-esc="agreement.signer_name"/></p>
                        <a href="/my/agreements" class="btn btn-primary mt-2">
                            <i class="fa fa-list"/> My Agreements
                        </a>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ============================================================
         Contract Not Available Page
    ============================================================ -->
    <template id="contract_not_available" name="Agreement Not Available">
        <t t-call="portal.portal_layout">
            <div class="row mt-4">
                <div class="col-md-8 offset-md-2">
                    <div class="alert alert-warning text-center">
                        <h2><i class="fa fa-exclamation-triangle"/> Agreement Not Available</h2>
                        <p>This agreement is not currently available for signing.</p>
                        <p t-if="error"><t t-esc="error"/></p>
                        <p>Current status: <strong><t t-esc="agreement.state"/></strong></p>
                        <a href="/my/agreements" class="btn btn-secondary mt-2">
                            <i class="fa fa-list"/> My Agreements
                        </a>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ============================================================
         Signing Success Page
    ============================================================ -->
    <template id="contract_signed_success" name="Agreement Signed Successfully">
        <t t-call="portal.portal_layout">
            <div class="row mt-4">
                <div class="col-md-10 offset-md-1">
                    <div class="card border-success">
                        <div class="card-header bg-success text-white">
                            <h3 class="mb-0">
                                <i class="fa fa-check-circle"/> Agreement Signed Successfully!
                            </h3>
                        </div>
                        <div class="card-body text-center">
                            <p class="lead">Thank you for signing the agreement.</p>

                            <div class="my-4">
                                <h4><t t-esc="agreement.name"/></h4>
                                <p>
                                    <strong>Signed by:</strong> <t t-esc="agreement.signer_name"/>
                                </p>
                                <p>
                                    <strong>Date:</strong>
                                    <span t-field="agreement.signature_date"/>
                                </p>
                            </div>

                            <p class="text-muted">
                                Our team will review your signed agreement and contact you shortly.
                            </p>

                            <a href="/my/agreements" class="btn btn-primary">
                                <i class="fa fa-list"/> My Agreements
                            </a>
                            <a href="/my" class="btn btn-secondary ml-2">
                                <i class="fa fa-home"/> My Account
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
