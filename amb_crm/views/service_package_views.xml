<?xml version="1.0" encoding="utf-8"?>
<data>
    <!-- Service Package Tree View -->
    <record id="view_amb_service_package_tree" model="ir.ui.view">
        <field name="name">amb.service.package.tree</field>
        <field name="model">amb.service.package</field>
        <field name="arch" type="xml">
            <list string="Service Packages" multi_edit="1">
                <field name="name"/>
                <field name="code"/>
                <field name="package_type"/>
                <field name="destination_country"/>
                <field name="total_fee"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Service Package Form View -->
    <record id="view_amb_service_package_form" model="ir.ui.view">
        <field name="name">amb.service.package.form</field>
        <field name="model">amb.service.package</field>
        <field name="arch" type="xml">
            <form string="Service Package">
                <sheet>
                    <group>
                        <group string="Package Info">
                            <field name="name"/>
                            <field name="code"/>
                            <field name="package_type"/>
                            <field name="destination_country"/>
                        </group>
                        <group string="Settings">
                            <field name="active"/>
                            <field name="allow_installment"/>
                        </group>
                    </group>
                    <group string="Fees">
                        <group>
                            <field name="base_fee"/>
                            <field name="assessment_fee"/>
                            <field name="processing_fee"/>
                        </group>
                        <group>
                            <field name="total_fee" readonly="1"/>
                        </group>
                    </group>
                    <group string="Product Mapping (Invoicing)">
                        <group>
                            <field name="product_id"/>
                        </group>
                        <group>
                            <field name="product_name" readonly="1"/>
                            <field name="product_sale_price" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Service Package Action -->
    <record id="action_amb_service_package" model="ir.actions.act_window">
        <field name="name">Service Packages</field>
        <field name="res_model">amb.service.package</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first service package
            </p>
        </field>
    </record>
</data>