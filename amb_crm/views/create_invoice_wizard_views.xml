<?xml version="1.0" encoding="utf-8"?>
<data>
    <!-- Create Invoice Wizard Form View -->
    <record id="view_amb_create_invoice_wizard_form" model="ir.ui.view">
        <field name="name">amb.create.invoice.wizard.form</field>
        <field name="model">amb.create.invoice.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Invoice">
                <group>
                    <group string="Payment Information">
                        <field name="payment_id" readonly="1"/>
                        <field name="journal_id" options="{'no_open': True}"/>
                    </group>
                    <group string="Invoice Date">
                        <field name="invoice_date"/>
                        <field name="due_date"/>
                    </group>
                </group>
                <group string="Invoice Line">
                    <group>
                        <field name="product_id" options="{'no_open': True}"/>
                        <field name="description"/>
                    </group>
                    <group>
                        <field name="quantity"/>
                        <field name="unit_price"/>
                        <field name="amount" readonly="1"/>
                    </group>
                </group>
                <footer>
                    <button name="action_create_invoice" string="Create Invoice" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Create Invoice Wizard Action -->
    <record id="action_amb_create_invoice_wizard" model="ir.actions.act_window">
        <field name="name">Create Invoice</field>
        <field name="res_model">amb.create.invoice.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</data>