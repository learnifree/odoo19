<?xml version="1.0" encoding="utf-8"?>
<data>
    <!-- Opportunity Tree View -->
    <record id="view_amb_opportunity_tree" model="ir.ui.view">
        <field name="name">amb.opportunity.tree</field>
        <field name="model">amb.opportunity</field>
        <field name="arch" type="xml">
            <list string="Opportunities" multi_edit="1">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="destination_country"/>
                <field name="program_interest"/>
                <field name="stage"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <!-- Opportunity Form View -->
    <record id="view_amb_opportunity_form" model="ir.ui.view">
        <field name="name">amb.opportunity.form</field>
        <field name="model">amb.opportunity</field>
        <field name="arch" type="xml">
            <form string="Opportunity">
                <header>
                    <button name="action_mark_contacted" string="Contacted" type="object" class="btn-primary" invisible="stage != 'new'"/>
                    <button name="action_mark_qualified" string="Qualified" type="object" class="btn-success" invisible="stage not in ('new', 'contacted')"/>
                    <button name="action_create_assessment" string="Create Assessment" type="object" class="btn-secondary" invisible="stage not in ('new', 'contacted', 'qualified')"/>
                    <button name="action_convert_to_client" string="Convert to Client" type="object" class="btn-success" invisible="stage != 'agreement'"/>
                    <button name="action_mark_lost" string="Mark as Lost" type="object" invisible="stage in ('converted', 'lost')"/>
                    <button name="action_reopen" string="Reopen" type="object" invisible="stage != 'lost'"/>
                    <field name="stage" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group string="Opportunity Details">
                            <field name="name" readonly="1"/>
                            <field name="partner_id" options="{'no_open': True}"/>
                            <field name="destination_country"/>
                            <field name="program_interest"/>
                            <field name="lead_id" readonly="1" options="{'no_open': True}"/>
                        </group>
                        <group string="Assignment">
                            <field name="user_id" widget="many2one_avatar_user"/>
                            <field name="team_id"/>
                            <field name="priority"/>
                        </group>
                    </group>
                    <group string="Financial">
                        <group>
                            <field name="planned_revenue"/>
                            <field name="total_payment" readonly="1"/>
                        </group>
                        <group>
                            <field name="next_follow_up"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Work History" name="work_history">
                            <field name="work_history_ids">
                                <list editable="bottom">
                                    <field name="company_name"/>
                                    <field name="position"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="is_current"/>
                                    <field name="years_employed" readonly="1"/>
                                    <field name="months_employed" readonly="1"/>
                                    <field name="total_years" readonly="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Consultation" name="consultation">
                            <field name="consultation_notes"/>
                        </page>
                        <page string="Stage Notes" name="stage_notes">
                            <field name="stage_description"/>
                        </page>
                        <page string="Lost Reason" name="lost" invisible="stage != 'lost'">
                            <field name="lost_reason"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Opportunity Search View -->
    <record id="view_amb_opportunity_search" model="ir.ui.view">
        <field name="name">amb.opportunity.search</field>
        <field name="model">amb.opportunity</field>
        <field name="arch" type="xml">
            <search string="Search Opportunities">
                <field name="partner_id"/>
                <field name="user_id"/>
            </search>
        </field>
    </record>

    <!-- Opportunity Kanban View -->
    <record id="view_amb_opportunity_kanban" model="ir.ui.view">
        <field name="name">amb.opportunity.kanban</field>
        <field name="model">amb.opportunity</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage" records_click="preview" quick_create="false">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="destination_country"/>
                <field name="program_interest"/>
                <field name="user_id"/>
                <field name="stage"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong class="oe_kanban_title">
                                    <field name="name"/>
                                </strong>
                                <div>
                                    <field name="partner_id"/>
                                </div>
                                <div class="oe_kanban_secondary">
                                    <field name="destination_country"/> - <field name="program_interest"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Opportunity Action -->
    <record id="action_amb_opportunity" model="ir.actions.act_window">
        <field name="name">Opportunities</field>
        <field name="res_model">amb.opportunity</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first opportunity
            </p>
        </field>
    </record>
</data>